@page
@model CisternasGAMC.Pages.Citizen.IndexModel
@{
    Layout = "_Layout";
}
<div class="content-fluid">
    <!-- Contenido principal -->
    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-6 offset-md-3">
                    <!-- Card con estilo de AdminLTE -->
                    <div class="card card-primary" style="border-radius: 15px; padding: 20px;">
                        <div class="card-header" style="border-radius: 15px; padding: 10px;">
                            <h3 class="card-title">
                                @if (Model.IsCisternAvailable)
                                {
                                    <text>@Model.CisternStatusMessage</text>
                                }
                                else
                                {
                                    <text>@Model.CisternStatusMessage</text>
                                }
                            </h3>
                        </div>
                        <div class="card-body">
                            <!-- Formulario de selección -->
                            <form method="get" asp-page="CisternCalendar">
                                <div class="form-group">
                                    <label for="distritoSelect">Selecciona tu Distrito</label>
                                    <select class="form-control form-control-lg" id="distritoSelect" name="SelectedDistrito" asp-for="SelectedDistrito">
                                        <option value="">Seleccione un distrito</option>
                                        @foreach (var distrito in Model.Distritos)
                                        {
                                            <option value="@distrito">@distrito</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label for="otbSelect">Selecciona un OTB</label>
                                    <select id="otbSelect" name="selectedOtb" class="form-control form-control-lg">
                                        <option value="">Seleccione un OTB</option>
                                        @foreach (var otb in Model.Otbs)
                                        {
                                            <option value="@otb.OtbId">@otb.Name</option>
                                        }
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-primary btn-block btn-lg">Enviar</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
@section Scripts {
    <script src="~/js/distritos.js"></script>
}
